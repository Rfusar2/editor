[32m+[m[32m    public class Parser[m
[32m+[m[32m    {[m
[32m+[m[32m        public string[] JSON___Str_Str(string json)[m[41m [m
[32m+[m[32m        //  {[m
[32m+[m[32m        //    "...": "...",[m
[32m+[m[32m        //    ...[m
[32m+[m[32m        //  }[m[41m [m
[32m+[m[32m        {[m
[32m+[m[32m            var lista = new List<string>();[m
[32m+[m[32m            bool inQuotes = false;[m
[32m+[m[32m            var current = "";[m
[32m+[m[32m            json = json.Trim().TrimStart('{').TrimEnd('}');[m
[32m+[m[32m            for (int i = 0; i < json.Length; i++)[m
[32m+[m[32m            {[m
[32m+[m[32m                char c = json[i];[m
[32m+[m[32m                if (c == '\"') {inQuotes = !inQuotes;}[m
[32m+[m[32m                if (c == ',' && !inQuotes)[m
[32m+[m[32m                {[m
[32m+[m[32m                    lista.Add(current.ToString().Trim());[m
[32m+[m[32m                    current = "";[m
[32m+[m[32m                }[m
[32m+[m[32m                else{ current = current + c;}[m
[32m+[m[32m            }[m
[32m+[m[32m            if (current.Length > 0){lista.Add(current.ToString().Trim());}[m
[32m+[m[32m            var result = new List<string>();[m
[32m+[m[32m            foreach (var pair in lista)[m
[32m+[m[32m            {[m
[32m+[m[32m                var parts = pair.Split(new[] { ':' }, 2);[m
[32m+[m[32m                if (parts.Length == 2)[m
[32m+[m[32m                {[m
[32m+[m[32m                    string key = parts[0].Trim().Trim('\"');[m
[32m+[m[32m                    string value = parts[1].Trim().Trim('\"');[m
[32m+[m[32m                    result.Add(key+" "+value);[m
[32m+[m[32m                }[m
[32m+[m[32m            }[m
[32m+[m[32m            return result.ToArray();[m
[32m+[m[32m        }[m
[32m+[m[32m    }[m
