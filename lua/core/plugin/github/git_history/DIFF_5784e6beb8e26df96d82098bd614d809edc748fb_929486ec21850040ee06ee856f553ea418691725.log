[32m+[m[32m                    }[m
[32m+[m[32m                    else{Log(prop.Name+": null");}[m
[32m+[m[32m                }[m
[32m+[m[32m                catch (Exception ex)[m
[32m+[m[32m                {[m
[32m+[m[32m                    Log(prop.Name+": [ERRORE] "+ex.Message);[m
[32m+[m[32m                }[m
[32m+[m[32m            }[m
[32m+[m[32m        }[m
[32m+[m[32m    }[m
